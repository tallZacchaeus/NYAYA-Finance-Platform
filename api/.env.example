APP_NAME="NYAYA Finance"
# Set to "production" on the VPS — disables debug pages and enables optimisations
APP_ENV=production
APP_KEY=
# Must be false in production — never expose stack traces
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Set to "error" in production to reduce noise
LOG_LEVEL=error

# --- Database ------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nyaya_finance
DB_USERNAME=nyaya
DB_PASSWORD=your_strong_password_here

# --- Session -------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Set to the root domain so the cookie is shared between api. and app. subdomains
SESSION_DOMAIN=.yourdomain.com
# Must be "none" when the frontend and API are on different subdomains (cross-origin SPA)
SESSION_SAME_SITE=none
# Must be true when same_site=none (browsers reject SameSite=None without Secure)
SESSION_SECURE_COOKIE=true

# --- CORS & Sanctum ------------------------------------------------------------
# The Next.js frontend URL — used by CORS and Sanctum stateful domains
FRONTEND_URL=https://app.yourdomain.com
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# --- Mail (Resend) -------------------------------------------------------------
MAIL_MAILER=resend
RESEND_API_KEY=re_your_key_here
MAIL_FROM_ADDRESS=finance@yourdomain.com
MAIL_FROM_NAME="NYAYA Finance"

# --- File Storage --------------------------------------------------------------
FILESYSTEM_DISK=public

# --- Queue & Cache -------------------------------------------------------------
QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log

# --- Redis (optional, recommended for production queue/cache) ------------------
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
