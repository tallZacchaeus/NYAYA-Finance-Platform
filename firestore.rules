rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function getRole() {
      return userDoc(request.auth.uid).data.role;
    }

    function isAdmin() {
      return signedIn() && getRole() == 'admin';
    }

    function isFinance() {
      return signedIn() && getRole() == 'finance';
    }

    function isAdminOrFinance() {
      return isAdmin() || isFinance();
    }

    function requestDoc(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId));
    }

    function ownsRequest(requestId) {
      return signedIn() && requestDoc(requestId).data.user_id == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.role == 'requester'
        && request.resource.data.email is string
        && request.resource.data.name is string;

      allow read: if isSelf(userId) || isAdminOrFinance();

      allow update: if isAdmin() || (
        isSelf(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
      );

      allow delete: if false;
    }

    match /requests/{requestId} {
      // Admins and finance can read all requests
      allow read: if isAdminOrFinance() || ownsRequest(requestId);

      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAdmin() || isFinance() || (
        ownsRequest(requestId)
        && resource.data.status == 'pending'
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.status == resource.data.status
      );

      allow delete: if isAdmin() || (
        ownsRequest(requestId)
        && resource.data.status == 'pending'
      );
    }

    match /request_documents/{documentId} {
      allow read: if isAdminOrFinance() || ownsRequest(resource.data.request_id);

      allow create: if signedIn()
        && request.resource.data.uploaded_by == request.auth.uid
        && (isAdminOrFinance() || ownsRequest(request.resource.data.request_id));

      allow update, delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow read: if isAdminOrFinance() || ownsRequest(resource.data.request_id);
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdminOrFinance() || (
        signedIn()
        && resource.data.user_id == request.auth.uid
      );

      allow create, delete: if isAdminOrFinance();

      allow update: if isAdmin() || (
        signedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.request_id == resource.data.request_id
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message
        && request.resource.data.created_at == resource.data.created_at
      );
    }

    match /audit_logs/{logId} {
      allow read: if isAdminOrFinance();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
