rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == 'admin';
    }

    function requestDoc(requestId) {
      return firestore.get(/databases/(default)/documents/requests/$(requestId));
    }

    function ownsRequest(requestId) {
      return signedIn() && requestDoc(requestId).data.user_id == request.auth.uid;
    }

    function validUpload() {
      return request.resource != null
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/(jpeg|png|webp)');
    }

    match /request-documents/{requestId}/{fileName=**} {
      allow read: if isAdmin() || ownsRequest(requestId);
      allow write: if validUpload() && (isAdmin() || ownsRequest(requestId));
    }

    match /receipts/{requestId}/{fileName=**} {
      allow read: if isAdmin() || ownsRequest(requestId);
      allow write: if validUpload() && isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
