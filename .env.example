# Laravel API — URL of the backend (used for Next.js rewrites in production)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Used server-side (SSR) for direct API calls — can be the internal/private network URL
API_URL=https://api.yourdomain.com

# Public app URL (used in server-side auth for Origin/Referer headers)
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
